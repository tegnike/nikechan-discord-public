#!/Users/nikenike/.hermes/hermes-agent/venv/bin/python
import argparse
import datetime as dt
import json
import os
import re
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

DISCORD_EPOCH_MS = 1420070400000
API = "https://discord.com/api/v10"
SUPABASE_RPC_TIMEOUT_SECONDS = 10
DISCORD_API_MAX_PAGES = 50
DISCORD_API_MAX_SECONDS = 20
QUERY_DROP_PHRASES = (
    "について",
    "に関して",
    "という",
    "同じように",
    "そのあとに",
    "その後に",
    "あとに",
    "最近",
    "調べて",
    "調査",
    "探して",
    "検索",
    "教えて",
    "ください",
    "お願い",
)
QUERY_STOPWORDS = {
    "さん",
    "ちゃん",
    "くん",
    "氏",
    "先生",
    "キャラ",
    "キャラクター",
}
QUERY_HONORIFICS_RE = re.compile(r"(さん|ちゃん|くん|氏|先生)")
QUERY_ASCII_RE = re.compile(r"[a-z0-9][a-z0-9_.-]{1,}")
QUERY_JA_RE = re.compile(r"[\u3040-\u30ff\u3400-\u9fffー]{2,}")


def load_env() -> dict:
    env = dict(os.environ)
    homes = []
    if env.get("HERMES_HOME"):
        homes.append(Path(env["HERMES_HOME"]))
    homes.append(Path.home() / ".hermes")
    homes.append(Path.home() / "WorkSpace" / "nikechan")
    for home in homes:
        p = home / ".env"
        if not p.exists():
            continue
        for line in p.read_text(encoding="utf-8", errors="replace").splitlines():
            if not line or line.startswith("#") or "=" not in line:
                continue
            k, v = line.split("=", 1)
            env.setdefault(k.strip(), v.strip())
    return env


ENV = load_env()
TOKEN = ENV.get("DISCORD_BOT_TOKEN", "").strip()
SUPABASE_URL = ENV.get("SUPABASE_URL", "").strip().rstrip("/")
SUPABASE_ANON_KEY = ENV.get("SUPABASE_ANON_KEY", "").strip()
SUPABASE_BOT_KEY = ENV.get("SUPABASE_DISCORD_BOT_KEY", "").strip()
ALLOWED_GUILDS = {
    g.strip()
    for g in ENV.get("DISCORD_ALLOWED_GUILDS", "").split(",")
    if g.strip()
}


class DiscordError(RuntimeError):
    pass


def supabase_rpc(name: str, payload: dict):
    if not SUPABASE_URL or not SUPABASE_ANON_KEY or not SUPABASE_BOT_KEY:
        raise DiscordError(
            "Discord history DB is not configured. "
            "SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_DISCORD_BOT_KEY are required."
        )
    req = urllib.request.Request(
        f"{SUPABASE_URL}/rest/v1/rpc/{name}",
        data=json.dumps(payload).encode("utf-8"),
        method="POST",
        headers={
            "apikey": SUPABASE_ANON_KEY,
            "Authorization": f"Bearer {SUPABASE_BOT_KEY}",
            "Content-Type": "application/json",
            "User-Agent": "nikechan-hermes-discord-history/2.0",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=SUPABASE_RPC_TIMEOUT_SECONDS) as resp:
            body = resp.read().decode("utf-8", errors="replace")
            try:
                return json.loads(body)
            except json.JSONDecodeError as exc:
                raise DiscordError("Discord history DB returned invalid JSON") from exc
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        try:
            detail = (json.loads(body) or {}).get("message") or "request rejected"
        except Exception:
            detail = "request rejected"
        raise DiscordError(f"Discord history DB HTTP {exc.code}: {detail}") from exc
    except (TimeoutError, urllib.error.URLError, OSError) as exc:
        raise DiscordError(f"Discord history DB unavailable: {type(exc).__name__}") from exc


def request(method: str, path: str, params: dict | None = None, body: dict | None = None):
    if not TOKEN:
        raise DiscordError("DISCORD_BOT_TOKEN is not configured")
    url = API + path
    if params:
        url += "?" + urllib.parse.urlencode({k: v for k, v in params.items() if v not in (None, "")})
    data = None if body is None else json.dumps(body).encode("utf-8")
    for attempt in range(6):
        req = urllib.request.Request(
            url,
            data=data,
            method=method,
            headers={
                "Authorization": f"Bot {TOKEN}",
                "Content-Type": "application/json",
                "User-Agent": "nikechan-hermes-discord-history/1.0",
            },
        )
        try:
            with urllib.request.urlopen(req, timeout=30) as resp:
                if resp.status == 204:
                    return None
                return json.loads(resp.read().decode("utf-8"))
        except urllib.error.HTTPError as e:
            body_text = e.read().decode("utf-8", errors="replace")
            if e.code == 429 and attempt < 5:
                retry_after = 1.0
                try:
                    retry_after = float((json.loads(body_text) or {}).get("retry_after") or retry_after)
                except Exception:
                    pass
                time.sleep(max(0.25, min(retry_after, 5.0)) + 0.1)
                continue
            raise DiscordError(f"Discord API {e.code}: {body_text}") from e
        except (TimeoutError, urllib.error.URLError, OSError) as e:
            if attempt < 5:
                time.sleep(0.5 + attempt * 0.5)
                continue
            raise DiscordError(f"Discord API network timeout: {type(e).__name__}: {e}") from e
    raise DiscordError("Discord API 429 retry limit exceeded")


def parse_time(value: str | None) -> dt.datetime | None:
    if not value:
        return None
    s = value.strip()
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    if re.fullmatch(r"\d{4}-\d{2}-\d{2}", s):
        s += "T00:00:00+00:00"
    parsed = dt.datetime.fromisoformat(s)
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    return parsed.astimezone(dt.timezone.utc)


def snowflake_from_time(ts: dt.datetime) -> str:
    ms = int(ts.timestamp() * 1000)
    return str((ms - DISCORD_EPOCH_MS) << 22)


def time_from_snowflake(snowflake: str) -> dt.datetime:
    ms = (int(snowflake) >> 22) + DISCORD_EPOCH_MS
    return dt.datetime.fromtimestamp(ms / 1000, tz=dt.timezone.utc)


def iso(ts: dt.datetime) -> str:
    return ts.astimezone(dt.timezone.utc).isoformat().replace("+00:00", "Z")


def unique_preserve_order(values: list[str]) -> list[str]:
    out = []
    seen = set()
    for value in values:
        if value and value not in seen:
            out.append(value)
            seen.add(value)
    return out


def query_terms(query: str) -> list[str]:
    raw = query.lower()
    cleaned = QUERY_HONORIFICS_RE.sub(" ", raw)
    for phrase in QUERY_DROP_PHRASES:
        cleaned = cleaned.replace(phrase, " ")
    cleaned = re.sub(r"[、。,.!?！？:：;；（）()【】「」『』\\[\\]<>]", " ", cleaned)

    terms = QUERY_ASCII_RE.findall(cleaned)
    for chunk in QUERY_JA_RE.findall(cleaned):
        token = chunk.strip("のがはをにもでとへ")
        if token in QUERY_STOPWORDS or len(token) < 2:
            continue
        terms.append(token)

    if QUERY_ASCII_RE.search(raw) and "スキル" in raw:
        terms.append("スキル")

    terms = unique_preserve_order(terms)
    return terms or [raw.strip()]


def query_term_groups(queries: list[str]) -> list[list[str]]:
    groups = []
    for query in queries:
        terms = query_terms(query)
        if terms and terms not in groups:
            groups.append(terms)
    return groups


def message_matches(hay: str, queries: list[str], groups: list[list[str]]) -> bool:
    for query in queries:
        literal = query.lower().strip()
        if literal and literal in hay:
            return True
    return any(all(term in hay for term in terms) for terms in groups)


def list_guilds():
    return request("GET", "/users/@me/guilds")


def list_channels(guild_id: str):
    return request("GET", f"/guilds/{guild_id}/channels")


def channel_info(channel_id: str):
    return request("GET", f"/channels/{channel_id}")


def assert_allowed_guild(guild_id: str | None, context: str = "channel"):
    if not ALLOWED_GUILDS:
        return
    if not guild_id or guild_id not in ALLOWED_GUILDS:
        allowed = ", ".join(sorted(ALLOWED_GUILDS))
        raise DiscordError(
            f"{context} is outside this profile's allowed Discord server. "
            f"guild_id={guild_id or 'unknown'} allowed_guilds={allowed}"
        )


def candidate_guilds(explicit_guild_id: str | None) -> list[dict]:
    if explicit_guild_id:
        assert_allowed_guild(explicit_guild_id, "requested guild")
        return [{"id": explicit_guild_id}]
    if ALLOWED_GUILDS:
        return [{"id": gid} for gid in sorted(ALLOWED_GUILDS)]
    return list_guilds()


def resolve_channel(channel: str, guild_id: str | None) -> dict:
    raw = channel.strip()
    raw = raw[2:-1] if raw.startswith("<#") and raw.endswith(">") else raw
    if raw.isdigit():
        ch = channel_info(raw)
        assert_allowed_guild(ch.get("guild_id"), f"channel {raw}")
        return {"id": ch["id"], "name": ch.get("name"), "guild_id": ch.get("guild_id"), "type": ch.get("type")}
    name = raw[1:] if raw.startswith("#") else raw
    guilds = candidate_guilds(guild_id)
    matches = []
    for g in guilds:
        for ch in list_channels(g["id"]):
            if ch.get("name") == name:
                assert_allowed_guild(g["id"], f"channel #{name}")
                matches.append({"id": ch["id"], "name": ch.get("name"), "guild_id": g["id"], "type": ch.get("type")})
    if not matches:
        raise DiscordError(f"channel not found: {channel}")
    if len(matches) > 1:
        raise DiscordError(f"ambiguous channel name {channel}; use channel id. matches={matches}")
    return matches[0]


def normalize_message(msg: dict, guild_id: str | None, channel_id: str) -> dict:
    author = msg.get("author") or {}
    jump = f"https://discord.com/channels/{guild_id or '@me'}/{channel_id}/{msg.get('id')}"
    return {
        "id": msg.get("id"),
        "timestamp": msg.get("timestamp"),
        "author": {
            "id": author.get("id"),
            "username": author.get("username"),
            "display_name": author.get("global_name"),
            "bot": author.get("bot", False),
        },
        "content": msg.get("content", ""),
        "attachments": [
            {"filename": a.get("filename"), "url": a.get("url"), "size": a.get("size")}
            for a in msg.get("attachments", [])
        ],
        "embeds": [
            {"title": e.get("title"), "url": e.get("url"), "description": e.get("description")}
            for e in msg.get("embeds", [])
        ],
        "reactions": [
            {"emoji": (r.get("emoji") or {}).get("name"), "count": r.get("count", 0)}
            for r in msg.get("reactions", [])
        ],
        "jump_url": jump,
    }


def fetch_messages_api(channel: str, guild_id: str | None, start: dt.datetime | None, end: dt.datetime | None, limit: int):
    ch = resolve_channel(channel, guild_id)
    channel_id = ch["id"]
    before = snowflake_from_time(end) if end else None
    out = []
    seen = set()
    pages = 0
    stop_reason = "complete"
    deadline = time.monotonic() + DISCORD_API_MAX_SECONDS
    while len(out) < limit and pages < DISCORD_API_MAX_PAGES and time.monotonic() < deadline:
        batch_limit = min(100, limit - len(out))
        params = {"limit": str(batch_limit)}
        if before:
            params["before"] = before
        batch = request("GET", f"/channels/{channel_id}/messages", params=params)
        pages += 1
        if not batch:
            break
        stop = False
        new_ids = 0
        for msg in batch:
            mid = msg["id"]
            if mid in seen:
                continue
            seen.add(mid)
            new_ids += 1
            ts = parse_time(msg.get("timestamp"))
            if start and ts and ts < start:
                stop = True
                continue
            if end and ts and ts > end:
                continue
            out.append(normalize_message(msg, ch.get("guild_id"), channel_id))
        oldest = min(batch, key=lambda m: int(m["id"]))["id"]
        if oldest == before or new_ids == 0:
            stop_reason = "no_progress"
            break
        before = oldest
        if stop or len(batch) < batch_limit:
            break
        time.sleep(0.05)
    else:
        if pages >= DISCORD_API_MAX_PAGES:
            stop_reason = "page_limit"
        elif time.monotonic() >= deadline:
            stop_reason = "time_limit"
    out.sort(key=lambda m: m["timestamp"] or "")
    return {
        "source": "discord_api_bounded_fallback",
        "channel": ch,
        "from": iso(start) if start else None,
        "to": iso(end) if end else None,
        "count": len(out),
        "pages": pages,
        "stop_reason": stop_reason,
        "messages": out,
    }


def fetch_message(channel: str, message_id: str, guild_id: str | None):
    ch = resolve_channel(channel, guild_id)
    channel_id = ch["id"]
    msg = request("GET", f"/channels/{channel_id}/messages/{message_id}")
    return {
        "channel": ch,
        "message": normalize_message(msg, ch.get("guild_id"), channel_id),
    }


def normalize_db_message(row: dict, guild_id: str) -> dict:
    author_name = row.get("author_name") or "unknown"
    channel_id = str(row.get("channel_id") or "")
    return {
        "id": row.get("message_id"),
        "timestamp": row.get("message_at"),
        "author": {
            "username": author_name,
            "display_name": author_name,
        },
        "content": row.get("content_snippet") or "",
        "attachment_count": int(row.get("attachment_count") or 0),
        "reply_to_message_id": row.get("reply_to_message_id"),
        "channel": {
            "id": channel_id,
            "name": row.get("channel_name"),
            "guild_id": guild_id,
        },
        "jump_url": row.get("jump_url"),
    }


def resolve_db_channel(channel: str, guild_id: str | None) -> dict:
    raw = channel.strip()
    raw = raw[2:-1] if raw.startswith("<#") and raw.endswith(">") else raw
    if raw.isdigit():
        resolved_guild = guild_id
        if not resolved_guild and len(ALLOWED_GUILDS) == 1:
            resolved_guild = next(iter(ALLOWED_GUILDS))
        assert_allowed_guild(resolved_guild, f"channel {raw}")
        return {
            "id": raw,
            "name": None,
            "guild_id": resolved_guild,
            "type": 0,
        }

    ch = resolve_channel(channel, guild_id)
    resolved_guild = str(ch.get("guild_id") or guild_id or "")
    assert_allowed_guild(resolved_guild, f"channel {ch.get('id')}")
    return ch


def db_fetch_messages(
    channel: str,
    guild_id: str | None,
    start: dt.datetime | None,
    end: dt.datetime | None,
    limit: int,
):
    ch = resolve_db_channel(channel, guild_id)
    resolved_guild = str(ch.get("guild_id") or guild_id or "")
    rows = supabase_rpc(
        "fetch_discord_history_v2",
        {
            "p_guild_id": resolved_guild,
            "p_channel_ids": [str(ch["id"])],
            "p_from": iso(start) if start else None,
            "p_to": iso(end) if end else None,
            "p_sort": "desc",
            "p_limit": min(max(limit, 1), 200),
        },
    )
    messages = [normalize_db_message(row, resolved_guild) for row in rows]
    messages.sort(key=lambda item: item.get("timestamp") or "")
    return {
        "source": "supabase_history_db",
        "channel": ch,
        "from": iso(start) if start else None,
        "to": iso(end) if end else None,
        "count": len(messages),
        "messages": messages,
    }


def db_search_messages(
    channel: str,
    guild_id: str | None,
    start: dt.datetime | None,
    end: dt.datetime | None,
    queries: list[str],
    result_limit: int,
    sort: str,
):
    ch = resolve_db_channel(channel, guild_id)
    resolved_guild = str(ch.get("guild_id") or guild_id or "")
    payload = {
        "p_guild_id": resolved_guild,
        "p_channel_ids": [str(ch["id"])],
        "p_queries": queries[:5],
        "p_from": iso(start) if start else None,
        "p_to": iso(end) if end else None,
        "p_sort": sort,
        "p_limit": min(max(result_limit, 1), 30),
    }
    rows = supabase_rpc("search_discord_history_v2", payload)
    summaries = []
    summary_error = None
    summaries_skipped_reason = None
    if sort == "asc":
        # The summary RPC is newest-first. Mixing it into an oldest-first
        # response makes the result chronologically misleading, so the exact
        # message result is the whole budget for deep-history requests.
        summaries_skipped_reason = "oldest_first_exact_messages_only"
    else:
        try:
            summaries = supabase_rpc(
                "search_discord_summaries_v2",
                {
                    "p_guild_id": resolved_guild,
                    "p_channel_ids": [str(ch["id"])],
                    "p_queries": queries[:5],
                    "p_from": iso(start) if start else None,
                    "p_to": iso(end) if end else None,
                    "p_limit": 12,
                },
            )
        except DiscordError as exc:
            # Summaries are optional context. Preserve valid exact-message
            # evidence when their independent RPC fails.
            summary_error = str(exc)
    results = [normalize_db_message(row, resolved_guild) for row in rows]
    return {
        "source": "supabase_history_db",
        "channel": ch,
        "from": iso(start) if start else None,
        "to": iso(end) if end else None,
        "query": queries[0],
        "query_terms": query_terms(queries[0]),
        "alternate_queries": queries[1:],
        "result_count": len(results),
        "summary_result_count": len(summaries),
        "summary_error": summary_error,
        "summaries_skipped_reason": summaries_skipped_reason,
        "results": results,
        "summary_results": summaries,
    }


def cmd_fetch(args):
    start = parse_time(args.from_time)
    end = parse_time(args.to_time)
    print(json.dumps(db_fetch_messages(args.channel, args.guild, start, end, args.limit), ensure_ascii=False, indent=2))


def cmd_fetch_api(args):
    start = parse_time(args.from_time)
    end = parse_time(args.to_time)
    print(json.dumps(fetch_messages_api(args.channel, args.guild, start, end, args.limit), ensure_ascii=False, indent=2))


def cmd_fetch_message(args):
    print(json.dumps(fetch_message(args.channel, args.message, args.guild), ensure_ascii=False, indent=2))


def cmd_search(args):
    start = parse_time(args.from_time)
    end = parse_time(args.to_time)
    queries = unique_preserve_order([args.query] + list(args.alternate_query or []))
    data = db_search_messages(
        args.channel,
        args.guild,
        start,
        end,
        queries,
        args.result_limit,
        args.sort,
    )
    print(json.dumps(data, ensure_ascii=False, indent=2))


def cmd_search_guild(args):
    raise DiscordError(
        "Server-wide history search is disabled. Specify one channel so the bounded DB RPC can enforce scope."
    )


def cmd_list_channels(args):
    guild_id = args.guild
    assert_allowed_guild(guild_id, "requested guild")
    channels = []
    for ch in list_channels(guild_id):
        if ch.get("type") not in (0, 5):
            continue
        channels.append(
            {
                "id": ch["id"],
                "name": ch.get("name"),
                "guild_id": guild_id,
                "type": ch.get("type"),
            }
        )
    channels.sort(key=lambda c: (c.get("name") or "", c["id"]))
    print(json.dumps({"guild_id": guild_id, "channels": channels}, ensure_ascii=False, indent=2))


def main():
    parser = argparse.ArgumentParser(
        description="Fetch/search the bounded Supabase Discord history archive for Hermes skills."
    )
    sub = parser.add_subparsers(dest="cmd", required=True)
    for name in ("fetch", "fetch-api", "search"):
        p = sub.add_parser(name)
        p.add_argument("--channel", required=True, help="Channel id, <#id>, or #name")
        p.add_argument("--guild", help="Guild id; required only for ambiguous #names")
        p.add_argument("--from", dest="from_time", help="UTC or offset ISO timestamp/date")
        p.add_argument("--to", dest="to_time", help="UTC or offset ISO timestamp/date")
        p.add_argument("--limit", type=int, default=200, help="Maximum messages to return")
        if name == "search":
            p.add_argument("--query", required=True)
            p.add_argument("--alternate-query", action="append", default=[])
            p.add_argument("--result-limit", type=int, default=30)
            p.add_argument("--sort", choices=("asc", "desc"), default="desc")
    p = sub.add_parser("search-guild")
    p.add_argument("--guild", required=True, help="Guild id to search. Must be in DISCORD_ALLOWED_GUILDS.")
    p.add_argument("--from", dest="from_time", help="UTC or offset ISO timestamp/date")
    p.add_argument("--to", dest="to_time", help="UTC or offset ISO timestamp/date")
    p.add_argument("--limit-per-channel", type=int, default=700, help="Maximum messages to scan per channel")
    p.add_argument("--query", required=True)
    p.add_argument("--alternate-query", action="append", default=[])
    p.add_argument("--result-limit", type=int, default=30)
    p = sub.add_parser("list-channels")
    p.add_argument("--guild", required=True, help="Guild id to list. Must be in DISCORD_ALLOWED_GUILDS.")
    p = sub.add_parser("fetch-message")
    p.add_argument("--channel", required=True, help="Channel id or <#id>")
    p.add_argument("--message", required=True, help="Message id")
    p.add_argument("--guild", help="Guild id; must be in DISCORD_ALLOWED_GUILDS if configured")
    args = parser.parse_args()
    try:
        if args.cmd == "fetch":
            cmd_fetch(args)
        elif args.cmd == "fetch-api":
            cmd_fetch_api(args)
        elif args.cmd == "fetch-message":
            cmd_fetch_message(args)
        elif args.cmd == "search":
            cmd_search(args)
        elif args.cmd == "search-guild":
            cmd_search_guild(args)
        elif args.cmd == "list-channels":
            cmd_list_channels(args)
    except DiscordError as e:
        print(json.dumps({"error": str(e)}, ensure_ascii=False), file=sys.stderr)
        sys.exit(2)


if __name__ == "__main__":
    main()
